# Robinhood credentials (never commit real values)
ROBINHOOD_USERNAME=
ROBINHOOD_PASSWORD=
# Optional: required if Robinhood prompts for MFA on login
ROBINHOOD_MFA_CODE=

# Bearer token required by Trading MCP (Authorization: Bearer <token>)
PORTFOLIO_API_TOKEN=

# Cache portfolio responses for 30-60 seconds (default 45)
PORTFOLIO_CACHE_SECONDS=45

# Server port for local development
PORT=8000

# Optional comma-separated CORS origins (leave empty for no CORS)
CORS_ORIGINS=
