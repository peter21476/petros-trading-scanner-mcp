PORT=3000
MCP_SERVER_API_KEY=
NODE_ENV=development
# Set to false on Heroku/cloud hosts where MarketWatch returns HTTP 401
MARKETWATCH_ENABLED=true
# Optional quote providers (checked before Nasdaq; Yahoo is last resort)
FINNHUB_API_KEY=
ALPHA_VANTAGE_API_KEY=
# Optional Robinhood portfolio API (portfolio-api/ FastAPI service)
PORTFOLIO_API_BASE_URL=http://localhost:8000/portfolio
PORTFOLIO_API_KEY=
# Alias supported: PORTFOLIO_API_TOKEN=
